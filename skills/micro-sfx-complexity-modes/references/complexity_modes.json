  "mode_escalation": {
    "increase_hit_count": "raise only when there are more visible anchors",
    "increase_layering_depth": "add anticipation/body/tail layers before raising gain",
    "increase_event_density": "group subhits if individual events are too fast to read",
    "increase_timing_jitter": "use jitter for humanized dense runs, never to hide poor sync",
