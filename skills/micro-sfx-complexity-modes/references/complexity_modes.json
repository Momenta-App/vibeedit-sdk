      "layering_depth": 1,
      "event_density": "major_events_only",
      "timing_jitter_ms": [0, 6],
      "volume_envelope": {
        "gain_db": [-18, -10],
        "attack_ms": [0, 3],
        "release_ms": [45, 140],
        "ducking": "none"
      },
      "motion_coupling": "anchor only to panel locks, hero text, major button confirmations, or object landings",
