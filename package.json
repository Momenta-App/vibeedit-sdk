{
  "name": "vibeedit",
  "version": "0.1.0-beta.1",
  "description": "VibeEdit-owned CompositionSpec, deterministic HTML motion runtime, catalog, and Node CLI.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    },
    "./spec": {
      "types": "./index.d.ts",
      "import": "./src/spec.js"
    },
    "./motion": {
      "types": "./motion.d.ts",
      "import": "./src/motion/index.js"
    },
    "./motion-atoms": "./catalog/motion-atoms/manifest.json",
    "./schema": "./schema/composition.schema.json",
    "./catalog": "./catalog/catalog.json"
  },
  "bin": {
    "vibeedit": "bin/vibeedit.js"
  },
  "files": [
    "bin/",
    "catalog/",
    "CHANGELOG.md",
    "docs/",
    "examples/",
    "experiments/",
    "index.d.ts",
    "LICENSE.md",
    "motion.d.ts",
    "runtime-models/",
    "apple-vision-runner/",
    "README.md",
    "SBOM.spdx.json",
    "schema/",
    "site/",
    "skills/",
    "src/",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "test": "node --test",
    "validate": "node scripts/validate-package.js",
    "catalog:build": "python3 scripts/normalize_catalog_examples.py && python3 scripts/generate_catalog_site.py",
    "previews:build": "uv run --extra browser python scripts/build_previews.py",
    "text:previews": "node scripts/build_text_effect_previews.mjs",
    "text:runtime:import": "python3 scripts/import_canonical_text_runtime.py",
    "text:fidelity": "node scripts/verify_canonical_text_fidelity.mjs",
    "sbom:build": "python3 scripts/generate_sbom.py",
    "pack:check": "npm pack --dry-run",
    "types:check": "tsc --noEmit -p tsconfig.types.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "playwright": "1.61.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "playwright": "1.61.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "keywords": [
    "vibeedit",
    "video",
    "editor",
    "motion-graphics",
    "ffmpeg",
    "ai-agents"
  ],
  "homepage": "https://vibeedit.com",
  "bugs": {
    "url": "https://github.com/Momenta-App/vibeedit-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Momenta-App/vibeedit-sdk.git"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "publishConfig": {
    "access": "public"
  }
}
